# GitHub Pages — project site at https://<user>.github.io/<repo>/
# Set locally before `npm run build`, or rely on `.github/workflows/deploy-github-pages.yml`
# NEXT_PUBLIC_BASE_PATH=/portfolio
#
# Canonical URL for metadata (include trailing slash; must match base path)
# NEXT_PUBLIC_SITE_URL=https://<user>.github.io/<repo>/

# Google Drive (or similar) link for CV / resume access request
NEXT_PUBLIC_CV_URL=

# Optional: full Instagram profile URL
NEXT_PUBLIC_INSTAGRAM_URL=
